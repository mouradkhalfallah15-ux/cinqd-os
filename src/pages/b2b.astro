---
import AIExecutiveChat from '../components/AIExecutiveChat.jsx';
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>CINQD B2B — Portail Entreprise</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="root" />
    <script>
      import { createElement } from 'react';
      import { createRoot } from 'react-dom/client';
      import { B2BPortal } from '../idx/index.js';
      createRoot(document.getElementById('root')).render(createElement(B2BPortal));
    </script>
    <AIExecutiveChat client:only="react" requireAuth={true} />
    <style is:global>
      html { font-family: 'Inter', system-ui, sans-serif; background: #020617; }
      body { margin: 0; }
    </style>
  </body>
</html>
