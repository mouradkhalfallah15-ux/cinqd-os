---
// src/pages/complexes/complexe-2/index.astro
const products = [
  { id: 'CINQD001', name: 'Détergent Multi-Usage', category: 'Nettoyage', price: '15.99 TND', stock: 'En Stock', image: '/images/product-1.jpg' },
  { id: 'CINQD002', name: 'Savon Liquide Main', category: 'Hygiène', price: '8.50 TND', stock: 'En Stock', image: '/images/product-2.jpg' },
  { id: 'CINQD003', name: 'Lave-Vitre Éclat', category: 'Nettoyage', price: '12.00 TND', stock: 'Rupture', image: '/images/product-3.jpg' },
  { id: 'CINQD004', name: 'Désinfectant Pin', category: 'Désinfection', price: '18.75 TND', stock: 'En Stock', image: '/images/product-4.jpg' },
];

const quotes = [
  { id: 'DEV001', client: 'Client A', amount: '1,250 TND', status: 'Accepté' },
  { id: 'DEV002', client: 'Client B', amount: '3,500 TND', status: 'Envoyé' },
  { id: 'DEV003', client: 'Client C', amount: '800 TND', status: 'Refusé' },
];
---

<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Commercial Complex | Cinqd</title>
</head>
<body class="bg-slate-900 text-white font-sans">

    <main class="container mx-auto px-4 py-12">

        <header class="flex items-center mb-12">
            <a href="/" class="text-red-500 hover:text-red-400 transition-colors duration-300 mr-4">&lt;</a>
            <h1 class="text-4xl font-extrabold">Commercial <span class="text-red-500">Complex</span></h1>
        </header>

        <!-- Product Catalog -->
        <div class="bg-slate-800 rounded-xl shadow-lg p-8 mb-8">
            <h2 class="text-2xl font-bold text-slate-200 mb-6">Catalogue Produits Cinqd</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                {products.map(p => (
                    <div class="bg-slate-900 rounded-lg shadow-md overflow-hidden group">
                        <img src={p.image} alt={p.name} class="w-full h-48 object-cover"/>
                        <div class="p-4">
                            <h3 class="text-lg font-bold text-white">{p.name}</h3>
                            <p class="text-slate-400">{p.category}</p>
                            <div class="flex justify-between items-center mt-4">
                                <span class="text-xl font-bold text-red-500">{p.price}</span>
                                <span class={`text-xs font-semibold px-2 py-1 rounded-full ${p.stock === 'En Stock' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}`}>{p.stock}</span>
                            </div>
                            <button class="w-full mt-4 bg-red-600 text-white font-bold py-2 px-4 rounded-lg hover:bg-red-700 transition-colors">Voir Détails</button>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Quote Management -->
        <div class="bg-slate-800 rounded-xl shadow-lg p-8">
            <h2 class="text-2xl font-bold text-slate-200 mb-6">Gestion des Devis</h2>
             <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-700">
                     <thead class="bg-slate-900">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Client</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Montant</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Statut</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Action</th>
                        </tr>
                    </thead>
                    <tbody class="bg-slate-800 divide-y divide-slate-700">
                        {quotes.map(q => (
                            <tr>
                                <td class="px-6 py-4 text-sm font-medium text-white">{q.id}</td>
                                <td class="px-6 py-4 text-sm">{q.client}</td>
                                <td class="px-6 py-4 text-sm">{q.amount}</td>
                                <td class="px-6 py-4 text-sm"><span class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${q.status === 'Accepté' ? 'bg-green-100 text-green-800' : q.status === 'Refusé' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800'}`}>{q.status}</span></td>
                                <td class="px-6 py-4 text-sm"><button class="text-red-500 hover:text-red-400">Gérer</button></td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>

    </main>

</body>
</html>
