---
// src/pages/complexes/complexe-5/index.astro
const employees = [
  { id: 'EMP001', name: 'Amine Ben Ali', role: 'Directeur Commercial', since: '2018' },
  { id: 'EMP002', name: 'Fatma Gharbi', role: 'Chef de Produit', since: '2020' },
  { id: 'EMP003', name: 'Mohamed Salah', role: 'Responsable Logistique', since: '2019' },
];

const franchisees = {
    "Tunis": [ { name: "Franchise Tunis Centre" }, { name: "Franchise La Marsa" } ],
    "Nabeul": [ { name: "Franchise Hammamet" } ],
    "Sfax": [ { name: "Franchise Sfax Ville" }, { name: "Franchise Sfax Sud" } ]
}
---

<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RH Complex | Cinqd</title>
</head>
<body class="bg-slate-900 text-white font-sans">

    <main class="container mx-auto px-4 py-12">

        <header class="flex items-center mb-12">
            <a href="/" class="text-red-500 hover:text-red-400 transition-colors duration-300 mr-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <h1 class="text-4xl font-extrabold">RH <span class="text-red-500">Complex</span></h1>
        </header>

        <!-- Employee List -->
        <div class="bg-slate-800 rounded-xl shadow-lg p-8 mb-8">
            <h2 class="text-2xl font-bold text-slate-200 mb-6">Liste des Employés</h2>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-700">
                    <thead class="bg-slate-900">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Nom</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Rôle</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Membre Depuis</th>
                        </tr>
                    </thead>
                    <tbody class="bg-slate-800 divide-y divide-slate-700">
                        {employees.map(e => (
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">{e.id}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">{e.name}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">{e.role}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">{e.since}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Franchisee Management -->
        <div class="bg-slate-800 rounded-xl shadow-lg p-8">
            <h2 class="text-2xl font-bold text-slate-200 mb-6">Gestion des Franchisés par Région</h2>
            <div class="space-y-4">
                {Object.keys(franchisees).map(region => (
                    <div>
                        <h3 class="text-xl font-bold text-red-500 mb-2">{region}</h3>
                        <ul class="list-disc list-inside bg-slate-900 p-4 rounded-lg">
                            {franchisees[region].map(f => (
                                <li class="text-slate-300">{f.name}</li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>

    </main>

</body>
</html>
