---
// src/pages/complexes/complexe-6/index.astro
const pointsOfSale = [
  { id: 'POS001', name: 'Casablanca Anfa', region: 'Grand Casablanca', status: 'Active' },
  { id: 'POS002', name: 'Rabat Agdal', region: 'Rabat-Salé-Kénitra', status: 'Active' },
  { id: 'POS003', name: 'Marrakech Gueliz', region: 'Marrakech-Safi', status: 'Inactive' },
  { id: 'POS004', name: 'Tanger Centre', region: 'Tanger-Tétouan-Al Hoceïma', status: 'Active' },
  { id: 'POS005', name: 'Fès Medina', region: 'Fès-Meknès', status: 'Maintenance' },
  // ... more data can be added here
];
---

<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logistics Complex - POS Management | Cinqd</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-slate-900 text-white font-sans">

    <main class="container mx-auto px-4 py-12">

        <header class="flex items-center mb-12">
            <a href="/" class="text-red-500 hover:text-red-400 transition-colors duration-300 mr-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <h1 class="text-4xl font-extrabold">
                Logistics <span class="text-red-500">Complex</span>
            </h1>
        </header>

        <div class="bg-slate-800 rounded-xl shadow-lg p-8">
            <div class="flex flex-wrap justify-between items-center mb-6 gap-4">
                <h2 class="text-2xl font-bold text-slate-200">Points of Sale Management (500)</h2>
                <div class="flex gap-4">
                    <input type="search" placeholder="Search POS..." class="w-full md:w-64 bg-slate-700 border-slate-600 rounded-md shadow-sm focus:ring-red-500 focus:border-red-500 sm:text-sm p-2">
                    <button class="bg-red-600 text-white font-bold py-2 px-4 rounded-lg shadow-md hover:bg-red-700 transition-colors duration-300 whitespace-nowrap">
                        Add New POS
                    </button>
                </div>
            </div>

            <!-- Stats -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                <div class="bg-slate-900 p-4 rounded-lg text-center">
                    <p class="text-slate-400 text-sm">Total</p>
                    <p class="text-2xl font-bold">500</p>
                </div>
                <div class="bg-slate-900 p-4 rounded-lg text-center">
                    <p class="text-slate-400 text-sm">Active</p>
                    <p class="text-2xl font-bold text-green-500">450</p>
                </div>
                <div class="bg-slate-900 p-4 rounded-lg text-center">
                    <p class="text-slate-400 text-sm">Inactive</p>
                    <p class="text-2xl font-bold text-red-500">30</p>
                </div>
                <div class="bg-slate-900 p-4 rounded-lg text-center">
                    <p class="text-slate-400 text-sm">Maintenance</p>
                    <p class="text-2xl font-bold text-yellow-500">20</p>
                </div>
            </div>

            <!-- POS Table -->
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-700">
                    <thead class="bg-slate-900">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">ID</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Name</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Region</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Status</th>
                            <th scope="col" class="relative px-6 py-3">
                                <span class="sr-only">Edit</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-slate-800 divide-y divide-slate-700">
                        {pointsOfSale.map(pos => (
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">{pos.id}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-300">{pos.name}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-300">{pos.region}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${pos.status === 'Active' ? 'bg-green-100 text-green-800' : pos.status === 'Inactive' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800'}`}>
                                        {pos.status}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a href="#" class="text-red-500 hover:text-red-400">Edit</a>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>

        </div>

    </main>

</body>
</html>
