---
// src/pages/complexes/complexe-7/index.astro
const feedbacks = [
  { client: 'Client X', subject: 'Suggestion d\'amélioration', message: 'Le produit est super, mais j\'aimerais une version... ' },
  { client: 'Client Y', subject: 'Problème de livraison', message: 'Ma commande est arrivée en retard...' },
];

const tickets = [
    { id: 'TICK001', subject: 'Erreur de facturation', status: 'Ouvert' },
    { id: 'TICK002', subject: 'Demande d\'information produit', status: 'Fermé' },
]
---

<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CRM Complex | Cinqd</title>
</head>
<body class="bg-slate-900 text-white font-sans">

    <main class="container mx-auto px-4 py-12">

        <header class="flex items-center mb-12">
            <a href="/" class="text-red-500 hover:text-red-400 transition-colors duration-300 mr-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            </a>
            <h1 class="text-4xl font-extrabold">CRM <span class="text-red-500">Complex</span></h1>
        </header>

        <!-- Customer Feedback -->
        <div class="bg-slate-800 rounded-xl shadow-lg p-8 mb-8">
            <h2 class="text-2xl font-bold text-slate-200 mb-6">Feedbacks Clients</h2>
            <div class="space-y-4">
                {feedbacks.map(f => (
                    <div class="bg-slate-900 p-4 rounded-lg">
                        <p class="font-bold text-red-400">{f.client} - <span class="text-slate-300">{f.subject}</span></p>
                        <p class="text-slate-400 mt-2">{f.message}</p>
                    </div>
                ))}
            </div>
        </div>

        <!-- Technical Support -->
        <div class="bg-slate-800 rounded-xl shadow-lg p-8">
            <h2 class="text-2xl font-bold text-slate-200 mb-6">Support Technique</h2>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-700">
                    <thead class="bg-slate-900">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Ticket ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Sujet</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Statut</th>
                        </tr>
                    </thead>
                    <tbody class="bg-slate-800 divide-y divide-slate-700">
                        {tickets.map(t => (
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-white">{t.id}</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">{t.subject}</td>
                                 <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class={`px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${t.status === 'Ouvert' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'}`}>
                                        {t.status}
                                    </span>
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
        </div>

    </main>

</body>
</html>
