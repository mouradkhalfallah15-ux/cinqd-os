---
// Quality Assurance module lives in /factory (IndustrialComplex › Assurance Qualité)
---

<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Qualité — CINQD Industrial</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#05080f] text-slate-200 font-sans min-h-screen flex items-center justify-center">

		<script>
			import { auth } from '../../firebase.js';
			import { onAuthStateChanged } from 'firebase/auth';
			onAuthStateChanged(auth, (user) => {
				if (!user) window.location.replace('/admin/login');
			});
		</script>

		<div class="text-center space-y-6 p-8">
			<div class="w-16 h-16 bg-green-600/10 border border-green-600/20 rounded-2xl flex items-center justify-center mx-auto">
				<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-500">
					<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
				</svg>
			</div>
			<div>
				<h1 class="text-2xl font-black text-white">Qualité</h1>
				<p class="text-slate-500 text-sm mt-2">Ce module est intégré dans le complexe industriel.</p>
			</div>
			<a href="/factory" class="inline-flex items-center gap-2 px-6 py-3 bg-green-700 hover:bg-green-600 text-white font-black rounded-xl transition-all text-sm">
				Aller à Industrial Complex
			</a>
		</div>

		<style is:global>
			html { font-family: 'Inter', system-ui, sans-serif; background: #05080f; }
		</style>
	</body>
</html>
