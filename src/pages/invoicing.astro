---
import InvoicingManager from '../components/InvoicingManager';
---

<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>CINQD Invoicing System</title>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#05080f] text-slate-200 font-sans min-h-screen">

		<!-- Auth guard: redirect to login if unauthenticated -->
		<script>
			import { auth } from '../firebase.js';
			import { onAuthStateChanged } from 'firebase/auth';
			onAuthStateChanged(auth, (user) => {
				if (!user) window.location.replace('/admin/login');
			});
		</script>

		<nav class="border-b border-slate-900 bg-slate-950/80 backdrop-blur-xl sticky top-0 z-50">
			<div class="max-w-[1600px] mx-auto px-6 h-16 flex items-center justify-between">
				<div class="flex items-center gap-3">
					<div class="w-8 h-8 bg-green-600 rounded flex items-center justify-center font-bold text-white shadow-lg shadow-green-600/20">F</div>
					<span class="text-sm font-black tracking-widest uppercase text-slate-400">Invoicing <span class="text-green-600">Center</span></span>
				</div>
				<div class="flex items-center gap-2">
					<div class="h-2 w-2 bg-green-500 rounded-full animate-pulse"></div>
					<span class="text-[10px] font-bold text-green-500 uppercase tracking-tighter">Automated Stock Sync Active</span>
				</div>
			</div>
		</nav>

		<main class="max-w-[1600px] mx-auto px-6 py-10">
			<header class="mb-10">
				<h1 class="text-3xl font-black text-white">إدارة الفواتير والوثائق الإدارية</h1>
				<p class="text-slate-500 text-sm mt-2 font-medium">نظام CINQD المتكامل لربط المبيعات والشراءات بحركة المخزن آلياً.</p>
			</header>

			<InvoicingManager client:only="react" />
		</main>

		<footer class="py-12 border-t border-slate-900 text-center text-slate-700 text-[10px] font-bold uppercase tracking-[0.4em]">
			CINQD Fiscal Framework • Invoicing Module 1.0 • Stock Integrated
		</footer>

		<style is:global>
			html { font-family: 'Inter', sans-serif; background: #05080f; }
			::-webkit-scrollbar { width: 4px; }
			::-webkit-scrollbar-track { background: #05080f; }
			::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
			@media print {
				nav, footer, button, header, .no-print { display: none !important; }
				body { background: white !important; color: black !important; }
				.print-only { display: block !important; }
				main { padding: 0 !important; margin: 0 !important; }
			}
		</style>
	</body>
</html>
