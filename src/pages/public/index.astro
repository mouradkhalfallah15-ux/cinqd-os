---
import AIExecutiveChat from '../../components/AIExecutiveChat.jsx';
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>CINQD — Service Client</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem;padding:2rem;">
      <img src="/favicon.svg" alt="CINQD" style="width:64px;height:64px;" />
      <h1 style="color:#f1f5f9;font-size:1.75rem;font-weight:800;margin:0;">CINQD</h1>
      <p style="color:#94a3b8;font-size:1rem;margin:0;text-align:center;max-width:400px;">
        Besoin d'aide ? Notre assistant IA est disponible en bas à droite.
      </p>
    </main>
    <AIExecutiveChat client:only="react" requireAuth={false} />
    <style is:global>
      html { font-family: 'Inter', system-ui, sans-serif; background: #020617; }
      body { margin: 0; }
    </style>
  </body>
</html>
