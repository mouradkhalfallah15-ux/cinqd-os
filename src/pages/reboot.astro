---
import RecettesWizardV2 from '../components/RecettesWizardV2';
import StockManagement from '../components/StockManagement';
import AiAuditor from '../components/AiAuditor';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>CINQD Industrial Reboot</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0a0f18] text-slate-200 font-sans selection:bg-red-500/30 min-h-screen">
        
        <!-- Top Status Bar -->
        <div class="bg-red-600 h-1 w-full fixed top-0 z-[60]"></div>
        
        <header class="border-b border-slate-800/60 bg-slate-900/80 backdrop-blur-xl sticky top-0 z-50 shadow-2xl">
            <div class="max-w-[1600px] mx-auto px-6 h-20 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-red-600 rounded-xl flex items-center justify-center font-black text-white shadow-lg shadow-red-600/40 transform -rotate-3 hover:rotate-0 transition-transform cursor-pointer">5D</div>
                    <div>
                        <h1 class="text-xl font-black tracking-tight text-white leading-none">REBOOT SYSTEM</h1>
                        <p class="text-[10px] text-red-500 font-bold uppercase tracking-[0.2em] mt-1">Industrial Control Environment</p>
                    </div>
                </div>

                <div class="hidden md:flex items-center gap-8 text-sm font-semibold text-slate-400">
                    <div class="flex items-center gap-2 px-4 py-2 bg-slate-800/50 rounded-lg border border-slate-700/50">
                        <div class="w-2 h-2 bg-green-500 rounded-full animate-ping"></div>
                        <span class="text-green-400">SERVER: 4325 ACTIVE</span>
                    </div>
                    <a href="/" class="hover:text-red-500 transition-colors">Main Console</a>
                    <a href="/dashboard" class="px-5 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-all shadow-lg shadow-red-600/20">Dashboard</a>
                </div>
            </div>
        </header>

        <main class="max-w-[1600px] mx-auto px-6 py-10">
            <div class="grid grid-cols-1 xl:grid-cols-12 gap-10">
                
                <!-- Left Control Panel: Production -->
                <div class="xl:col-span-7">
                    <div class="group relative bg-slate-900/40 border border-slate-800 rounded-[2rem] overflow-hidden backdrop-blur-sm transition-all hover:border-red-500/30">
                        <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
                            <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path></svg>
                        </div>
                        <div class="p-10">
                            <div class="flex items-center gap-4 mb-8">
                                <div class="w-12 h-12 rounded-2xl bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-500">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
                                </div>
                                <div>
                                    <h2 class="text-2xl font-bold text-white leading-none">Production Wizard</h2>
                                    <p class="text-slate-500 text-sm mt-1 font-medium italic">IA CINQD - Calcul de rendement optimal</p>
                                </div>
                            </div>
                            <div class="relative z-10">
                                <RecettesWizardV2 client:only="react" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Control Panel: Inventory -->
                <div class="xl:col-span-5">
                    <div class="bg-slate-900/40 border border-slate-800 rounded-[2rem] overflow-hidden backdrop-blur-sm hover:border-blue-500/30 transition-all">
                        <div class="p-10">
                            <div class="flex items-center gap-4 mb-8">
                                <div class="w-12 h-12 rounded-2xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-500">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8V21H3V8M1 3H23V8H1V3ZM10 12H14"></path></svg>
                                </div>
                                <div>
                                    <h2 class="text-2xl font-bold text-white leading-none">Inventory Stats</h2>
                                    <p class="text-slate-500 text-sm mt-1 font-medium italic">Monitoring des flux logistiques</p>
                                </div>
                            </div>
                            <div class="relative z-10">
                                <StockManagement client:only="react" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <!-- Fixed AI Auditor Agent -->
        <div class="fixed bottom-10 right-10 z-[100] group">
            <div class="absolute -inset-4 bg-red-600/20 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <AiAuditor client:only="react" />
        </div>

        <footer class="py-12 border-t border-slate-800/30 bg-slate-950/20 mt-20">
            <div class="max-w-[1600px] mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="text-slate-500 text-sm font-medium">
                    &copy; 2024 CINQD Industrial Framework • Build 1.0.4-REBOOT
                </div>
                <div class="flex gap-6 text-xs font-bold text-slate-600 uppercase tracking-widest">
                    <span>Firewall: Active</span>
                    <span>Firebase: Syncing</span>
                    <span>Node: Stable</span>
                </div>
            </div>
        </footer>

        <style is:global>
            :root {
                --red-main: #dc2626;
            }
            body {
                background-image: 
                    radial-gradient(circle at 20% 30%, rgba(220, 38, 38, 0.03) 0%, transparent 40%),
                    radial-gradient(circle at 80% 70%, rgba(37, 99, 235, 0.03) 0%, transparent 40%);
                background-attachment: fixed;
            }
            /* Hide scrollbar but keep functionality */
            .no-scrollbar::-webkit-scrollbar {
                display: none;
            }
            .no-scrollbar {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
        </style>
	</body>
</html>
